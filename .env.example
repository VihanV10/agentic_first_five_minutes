# AWS Bedrock — used by the investigation agent (lib/agent.ts).
# Copy to .env and set your values. Do not commit .env.
#
# Create access keys: AWS Console → IAM → Users → Security credentials → Create access key
# Ensure the user has permission for bedrock:InvokeModel (e.g. AmazonBedrockFullAccess or a minimal policy).
#
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_access_key_id
# AWS_SECRET_ACCESS_KEY=your_secret_access_key
# BEDROCK_MODEL_ID=meta.llama3-8b-instruct-v1:0
